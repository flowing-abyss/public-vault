{
	"schemaVersion": "0.1.0",
	"name": "video (content)",
	"behavior": "create",
	"noteContentFormat": "\n>[!link]- Youtube\n> <iframe title=\"{{schema:name}}\" src=\"{{schema:@VideoObject:embedUrl}}?feature=oembed\" height=\"113\" width=\"200\" style=\"aspect-ratio: 1.76991 / 1; width: 100%; height: 100%;\" allowfullscreen=\"\" allow=\"fullscreen\"></iframe>\n\n<%*\nconst template = `---\ntags:\n  - mark/addition/aggregator\n---\n\n{{selectorHtml:.ytd-transcript-segment-list-renderer|first|replace:\\\"&nbsp;\\\":\\\" \\\"|join|markdown}}\n`;\n\nawait tp.file.create_new(template, \"{{schema:name|safe_name}}\" + \" - content\", false, \"base/additions\");\n-%>",
	"properties": [
		{
			"name": "tags",
			"value": "source/video/recording, mark/fleeting",
			"type": "multitext"
		},
		{
			"name": "aliases",
			"value": "",
			"type": "multitext"
		},
		{
			"name": "status",
			"value": "🟥",
			"type": "text"
		},
		{
			"name": "cover",
			"value": "{{schema:thumbnailUrl|slice:0}}",
			"type": "text"
		},
		{
			"name": "published",
			"value": "{{schema:uploadDate|date:YYYY-MM-DD}}",
			"type": "date"
		},
		{
			"name": "created",
			"value": "{{date|\\\"YYYY-MM-DDTHH:mm:ssZ\\\"}}",
			"type": "datetime"
		},
		{
			"name": "updated",
			"value": "{{date|\\\"YYYY-MM-DDTHH:mm:ssZ\\\"}}",
			"type": "datetime"
		},
		{
			"name": "category",
			"value": "",
			"type": "multitext"
		},
		{
			"name": "meta",
			"value": "",
			"type": "multitext"
		},
		{
			"name": "problem",
			"value": "",
			"type": "multitext"
		},
		{
			"name": "creator",
			"value": "{{author|split:\\\", \\\"|wikilink|join}}",
			"type": "multitext"
		},
		{
			"name": "production",
			"value": "",
			"type": "multitext"
		},
		{
			"name": "url",
			"value": "[{{domain}}]({{url}})",
			"type": "text"
		},
		{
			"name": "addition",
			"value": "[[{{schema:name|safe_name}} - content|📄]]",
			"type": "multitext"
		}
	],
	"triggers": [
		"https://www.youtube.com/"
	],
	"noteNameFormat": "{{schema:name|safe_name}}",
	"path": "sources"
}